# ─── Web Intelligence Engine — Environment Config ────────────────────────────
# Copy this file to .env and fill in your values

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8002
DEBUG=false

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_URL=postgresql+asyncpg://postgres:password@localhost:5432/web_intelligence

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URL=mongodb://localhost:27017
MONGO_DB=web_intelligence

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Search APIs (at least one required — DuckDuckGo free fallback if none) ───
SERPAPI_KEY=9308b96556ba35cc72d7964f2d91cde307cf5ecfc5ae842aae43bd2f5d505aaa
# GOOGLE_CSE_KEY=your_google_cse_key_here
# GOOGLE_CSE_ID=your_google_cse_id_here
# BING_API_KEY=your_bing_api_key_here

# ── Claude AI (required for AI scoring — heuristic fallback if missing) ───────
ANTHROPIC_API_KEY=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
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Workers ───────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=20
MAX_RETRIES=3
RETRY_BACKOFF_BASE=2.0
REQUEST_TIMEOUT=25

# ── Scraping ──────────────────────────────────────────────────────────────────
USE_HEADLESS=false
ROTATE_USER_AGENTS=true
MIN_RELEVANCE_SCORE=0.40
MAX_CONTENT_TOKENS=8000

# ── Rate Limiting ─────────────────────────────────────────────────────────────
REQUESTS_PER_DOMAIN_PER_MINUTE=10
